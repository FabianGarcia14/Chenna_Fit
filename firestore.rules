rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can access their own profile and logs
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Cascade rules for the dailyLogs subcollection
      match /dailyLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Cascade rules for the recentMeals subcollection
      match /recentMeals/{comboId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Global cache for scanned products
    match /scanned_products/{barcode} {
      allow read, write: if request.auth != null;
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
